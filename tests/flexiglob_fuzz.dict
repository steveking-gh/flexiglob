# Operators
"REVERSE"
"SORT"
"FILTER"

# Parentheses
"("
")"

# Wildcards
"*"
"**"
"?"

# Bracket sets
"["
"]"
"[^"
"[a-z]"
"[A-Z]"
"[0-9]"

# Escape sequences (backslash doubled per libFuzzer dict format)
"\\("
"\\)"
"\\*"
"\\?"
"\\["
"\\\\"

# Common path and name tokens
"/"
".text"
"src/"
".rs"
".txt"
